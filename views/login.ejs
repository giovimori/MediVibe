<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MediVibe - Autenticazione Accesso</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar">
        <a href="/" class="logo">MediVibe</a>
        <div class="nav-links">
            <a href="/login" style="color: var(--primary);">Accesso Pazienti</a>
            <a href="/register">Registrazione</a>
        </div>
    </nav>

    <div class="container">
        <div class="card">
            <h1>Accesso al Portale Sanitario</h1>
            <p class="text-muted text-center" style="margin-bottom: 24px; font-size: 14px;">Inserisci le tue credenziali per accedere al tuo fascicolo sanitario digitale.</p>
            
            <% if (error) { %>
                <div class="error"><%= error %></div>
            <% } %>

            <form action="/login" method="POST">
                <div class="form-group">
                    <label for="email">Indirizzo Email</label>
                    <input type="email" id="email" name="email" required placeholder="mario.rossi@example.com">
                </div>
                
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required placeholder="Scrivi la tua password">
                </div>
                
                <button type="submit" style="margin-top: 10px;">Accedi all'Area Riservata</button>
            </form>
            
            <div class="text-center" style="margin-top: 24px;">
                <p style="font-size: 14px; color: var(--text-muted);">Non possiedi ancora un account digitale? <br><a href="/register" style="display: inline-block; margin-top: 8px;">Crea il tuo fascicolo sanitario</a></p>
            </div>
        </div>
    </div>
</body>
</html>
