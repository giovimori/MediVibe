<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MediVibe - Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar">
        <a href="/" class="logo">MediVibe</a>
        <div class="nav-links">
            <a href="/dashboard">Dashboard</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>

    <div class="container" style="max-width: 1200px;">
        <h1>Benvenuto, <%= user.name %>!</h1>
        <p class="text-center" style="color: var(--text-muted);">La tua cartella clinica digitale</p>
        
        <div class="grid">
            <div class="card wide" style="margin-top: 0;">
                <h3>I Tuoi Sintomi</h3>
                <div style="background: rgba(0,0,0,0.3); padding: 15px; border-radius: 10px; margin-bottom: 20px;">
                    <%- user.symptoms ? user.symptoms : "<em>Nessun sintomo registrato.</em>" %>
                </div>

                <form action="/dashboard/symptoms" method="POST">
                    <div class="form-group">
                        <label for="symptoms">Aggiorna Sintomi (HTML consentito per formattazione)</label>
                        <textarea id="symptoms" name="symptoms" rows="4" placeholder="Descrivi qui come ti senti..."><%= user.symptoms || '' %></textarea>
                    </div>
                    <button type="submit" class="btn-secondary">Salva Appunti</button>
                </form>
            </div>

            <div class="card wide" style="margin-top: 0;">
                <h3>I Tuoi Referti</h3>
                <% if (reports && reports.length > 0) { %>
                    <% reports.forEach(function(report) { %>
                        <div class="report-card">
                            <h3 style="font-size: 18px; color: var(--primary);"><%= report.title %></h3>
                            <a href="/report?id=<%= report.id %>" class="btn" style="padding: 8px 15px; font-size: 14px; margin-top: 10px;">Visualizza Referto</a>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p style="color: var(--text-muted);">Nessun referto disponibile al momento.</p>
                <% } %>
                
                <hr style="margin: 20px 0; border: none; border-top: 1px solid var(--card-border);">
                
                <h4>Carica un nuovo referto o esame</h4>
                <form action="/upload" method="POST" enctype="multipart/form-data" style="margin-top: 15px;">
                    <div class="form-group">
                        <label for="title">Titolo Documento</label>
                        <input type="text" id="title" name="title" required placeholder="Es: Analisi del Sangue">
                    </div>
                    <div class="form-group">
                        <label for="reportFile">File (PDF, JPG, ...nessun controllo!)</label>
                        <input type="file" id="reportFile" name="reportFile" required style="padding: 8px;">
                    </div>
                    <button type="submit">Carica File</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
