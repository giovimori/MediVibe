<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MediVibe - Direzione Sanitaria (Admin)</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar" style="border-bottom: 3px solid var(--danger);">
        <a href="/" class="logo" style="color: var(--danger);">MediVibe Direzione</a>
        <div class="nav-links">
            <a href="/logout" style="color: var(--danger); font-weight: 600;">Termina Sessione Criptata</a>
        </div>
    </nav>

    <div class="container" style="max-width: 1100px;">
        
        <div class="card wide" style="margin-bottom: 30px; border-color: var(--primary);">
            <h3 style="color: var(--primary-hover); margin-bottom: 15px;">➕ Inserisci Medico Strutturista</h3>
            <form action="/admin/add-doctor" method="POST" style="margin-top: 0;">
                <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                    <div class="form-group" style="flex: 1; min-width: 200px;">
                        <label for="name">Nome Dottore</label>
                        <input type="text" id="name" name="name" required placeholder="Dott. / Dott.ssa ...">
                    </div>
                    <div class="form-group" style="flex: 1; min-width: 200px;">
                        <label for="email">Email Ufficiale</label>
                        <input type="email" id="email" name="email" required placeholder="email@medivibe.com">
                    </div>
                    <div class="form-group" style="flex: 1; min-width: 200px;">
                        <label for="password">Password di Accesso</label>
                        <input type="password" id="password" name="password" required>
                    </div>
                </div>
                <button type="submit" style="align-self: flex-start; margin-top: 10px;">Accredita Dottore</button>
            </form>
        </div>

        <div class="card wide">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #e2e8f0; padding-bottom: 20px; margin-bottom: 30px;">
                <h1 style="margin: 0; color: var(--text-main); font-size: 24px;">Pannello di Direzione Sanitaria</h1>
                <span style="background: var(--danger-bg); color: var(--danger); padding: 6px 12px; border-radius: 6px; font-size: 13px; font-weight: 600; border: 1px solid #fca5a5;">ACCESSO DI LIVELLO 3</span>
            </div>
            
            <p class="text-center" style="color: var(--text-muted); margin-bottom: 30px; background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px solid #e2e8f0;">Area riservata esclusivamente al personale autorizzato per la gestione anagrafiche e ruoli.</p>

            <h3 style="color: var(--text-main); font-size: 18px; margin-bottom: 20px;">Anagrafica Pazienti e Personale</h3>
            
            <div style="overflow-x: auto; border: 1px solid var(--card-border); border-radius: 8px;">
                <table style="margin-top: 0;">
                    <thead>
                        <tr>
                            <th>Identificativo</th>
                            <th>Nominativo Completo</th>
                            <th>Recapito Email</th>
                            <th>Qualifica / Ruolo</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(function(u) { %>
                            <tr>
                                <td style="font-family: monospace; color: var(--text-muted);">#ID-<%= u.id %></td>
                                <td style="font-weight: 500; color: var(--text-main);"><%= u.name %></td>
                                <td><a href="mailto:<%= u.email %>" style="color: var(--primary); text-decoration: none;"><%= u.email %></a></td>
                                <td>
                                    <% if(u.role === 'admin') { %>
                                        <span style="display: inline-block; padding: 4px 10px; border-radius: 4px; background: var(--danger-bg); color: var(--danger); font-size: 12px; font-weight: 600; border: 1px solid #fca5a5;">DIREZIONE</span>
                                    <% } else if(u.role === 'doctor') { %>
                                        <span style="display: inline-block; padding: 4px 10px; border-radius: 4px; background: #d1fae5; color: #047857; font-size: 12px; font-weight: 600; border: 1px solid #6ee7b7;">MEDICO CURANTE</span>
                                    <% } else { %>
                                        <span style="display: inline-block; padding: 4px 10px; border-radius: 4px; background: var(--primary-light); color: var(--primary-hover); font-size: 12px; font-weight: 600; border: 1px solid rgba(2, 132, 199, 0.2);">PAZIENTE</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            
        </div>
    </div>
</body>
</html>
